<?xml version="1.0" encoding="utf-8"?>
<!-- Trading Widget Layout — Sovereign Vantage V5.5.92 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#BF021508">

    <!-- Header row: title + status indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sovereign Vantage"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="#4CAF50"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Clickable body area -->
    <LinearLayout
        android:id="@+id/widget_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- P/L row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/widget_pnl_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P/L"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/widget_pnl_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_pnl_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00%"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/widget_positions_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Positions"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/widget_positions_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Trades + Margin row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/widget_trades_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trades"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/widget_trades_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/widget_margin_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Margin"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/widget_margin_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/widget_margin_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAFE"
                    android:textColor="#4CAF50"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Stop/Emergency button -->
    <Button
        android:id="@+id/widget_stop_button"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:text="STOP"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B71C1C"
        android:layout_marginTop="4dp" />

</LinearLayout>
