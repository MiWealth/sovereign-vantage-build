<?xml version="1.0" encoding="utf-8"?>
<!--
    SOVEREIGN VANTAGE — Portfolio Widget Layout
    Shows total value, daily P&L, and position count
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FF021508">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Portfolio"
        android:textColor="#FFD700"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Total Value -->
    <TextView
        android:id="@+id/widget_total_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="A$0.00"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Daily P&L + Positions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_daily_pnl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+A$0.00"
            android:textColor="#00C853"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/widget_positions_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Positions"
            android:textColor="#A0A0A0"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/widget_trading_button"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="Trade"
            android:textColor="#021508"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#FFD700"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_popup_sync"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="Refresh"
            android:scaleType="centerInside" />
    </LinearLayout>

</LinearLayout>
