<?xml version="1.0" encoding="utf-8"?>
<!-- Enforce HTTPS everywhere. Debug cert trust for testnet APIs. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow debug CA for testnet connections during development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
