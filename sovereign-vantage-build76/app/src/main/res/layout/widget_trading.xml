<?xml version="1.0" encoding="utf-8"?>
<!--
    SOVEREIGN VANTAGE — Trading Widget Layout
    Imperial green/gold theme with emergency stop button

    IDs must match TradingWidgetProvider.kt exactly.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FF021508">

    <!-- Header: Title + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sovereign Vantage"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textSize="12sp"
            android:textColor="#00C853" />
    </LinearLayout>

    <!-- Body: clickable area for opening app -->
    <LinearLayout
        android:id="@+id/widget_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- P/L Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_pnl_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A$0.00"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_pnl_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="(0.00%)"
                android:textColor="#FFD700"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Stats Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <!-- Positions -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_positions_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Positions"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_positions_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Trades -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_trades_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trades"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_trades_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Margin -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_margin_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Margin"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/widget_margin_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/widget_margin_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="OK"
                        android:textColor="#00C853"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Row: Stop + Refresh buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/widget_stop_button"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="3"
            android:text="⬛ STOP"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#CCFF1744"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/widget_refresh_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_popup_sync"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="Refresh"
            android:scaleType="centerInside" />
    </LinearLayout>

</LinearLayout>
